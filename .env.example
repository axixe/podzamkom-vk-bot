# VK application token
VK_TOKEN=vk1.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret from VK Callback API settings
VK_CALLBACK_SECRET=change-me-callback-secret

# Comma-separated list of admin user IDs
ADMIN_USER_IDS=1,2,3

# SQLite database path
DB_PATH=data/app.db

# Confirmation code from VK Callback API settings
VK_CONFIRMATION_CODE=change-me-confirmation-code
